# IDMP container to watch (must be on the same Docker host)
IDMP_CONTAINER_NAME=idmp-tsdb-tdgpt-idmp

# How long to wait after a register-code request before alerting (seconds)
VERIFY_EMAIL_TIMEOUT_SECONDS=90

# Where to send alerts when verification email was never sent or failed
ALERT_TO=ops@example.com
ALERT_FROM=idmp-monitor@example.com

# SMTP settings for alert emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Optional: also run a proactive connectivity check on this interval (seconds).
# Set to 0 to disable. Uses IDMP /api/v1/system/email/default-connectivity.
PROBE_INTERVAL_SECONDS=0
IDMP_BASE_URL=http://host.docker.internal:6042

# Host port published for the monitor health endpoint
MONITOR_HOST_PORT=18088
